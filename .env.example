# -----------------------------------------------------------------------------
# API Keys
# Get your TVDB API key at: https://thetvdb.com/api-information
# Get your TMDB Read Access Token at: https://www.themoviedb.org/settings/api
# -----------------------------------------------------------------------------
TVDB_API_KEY=
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Language
# ISO 639-2 code: fra, eng, spa, deu, ita, jpn, kor, por, rus, zho...
# -----------------------------------------------------------------------------
LANGUAGE=fra

# -----------------------------------------------------------------------------
# Translation sources
# PRIMARY_TRANSLATION_SOURCE: tvdb | tmdb
# SECONDARY_TRANSLATION_SOURCE: tvdb | tmdb | (leave empty for no fallback)
# -----------------------------------------------------------------------------
PRIMARY_TRANSLATION_SOURCE=tvdb
SECONDARY_TRANSLATION_SOURCE=tmdb

# -----------------------------------------------------------------------------
# Translation modes (per field)
# always  = always replace with translated value
# never   = keep original Skyhook value
# native  = replace only if the show's original language matches LANGUAGE
# -----------------------------------------------------------------------------
SHOW_TITLE_MODE=native
SHOW_OVERVIEW_MODE=always
SEASON_TITLE_MODE=native
SEASON_OVERVIEW_MODE=always
EPISODE_TITLE_MODE=native
EPISODE_OVERVIEW_MODE=always
